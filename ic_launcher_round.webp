<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="6dp"
    android:background="@android:color/white">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="center_horizontal">

        <!-- Left Logo centered -->
        <ImageView
            android:id="@+id/logoLeft"
            android:layout_width="132dp"
            android:layout_height="132dp"
            android:src="@drawable/budget"
            android:layout_gravity="center"
            android:contentDescription="Budget Logo" />

        <!-- Current Balance container -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/currentBalanceCurrency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/currentBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:letterSpacing="0.05"
                android:fontFamily="monospace"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Required Balance container (similar style, subtle red) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/requiredBalanceCurrency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#B00020"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/requiredBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#B00020"
                android:letterSpacing="0.05"
                android:fontFamily="monospace"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <EditText
            android:id="@+id/topUpAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter top-up amount"
            android:inputType="numberDecimal"
            android:layout_marginBottom="20dp"
            android:padding="10dp"
            android:backgroundTint="#6200EE"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="sans-serif" />

        <Button
            android:id="@+id/saveTopUpButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="@android:color/white"
            android:backgroundTint="#6C6575"
            android:padding="12dp"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/closeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Close"
            android:textColor="#6200EE"
            android:backgroundTint="@android:color/white"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
