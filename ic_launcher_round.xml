<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/bg_gradient_card"
    tools:context=".dashboard"
    android:padding="2dp">

    <!--  Budget Balance Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/balanceCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        android:layout_marginTop="1dp"
        android:layout_margin="5dp"
        android:background="@drawable/bg_gradient_card"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_card"
            android:padding="20dp">

            <!-- Left Logo -->
            <ImageView
                android:id="@+id/logoLeft"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/budget"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- Right Logo -->
            <ImageView
                android:id="@+id/logoRight"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/track"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- User Name -->
            <TextView
                android:id="@+id/userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:text="M Ndimande"
                android:textAlignment="textStart"
                android:textColor="@color/black"
                android:textSize="16sp"
                app:layout_constraintEnd_toStartOf="@id/logoRight"
                app:layout_constraintHorizontal_bias="0.065"
                app:layout_constraintStart_toEndOf="@id/logoLeft"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Available Budget Label -->
            <TextView
                android:id="@+id/balanceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Budget"
                android:textSize="16sp"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/logoLeft"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                android:gravity="center"/>

            <!-- Available Budget Amount -->
            <TextView
                android:id="@+id/balanceAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00.00 ZAR"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/teal_700"
                app:layout_constraintTop_toBottomOf="@id/balanceLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"/>



            <!-- Main Budget Label -->
            <TextView
                android:id="@+id/mainBudgetLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Main Budget"
                android:textSize="16sp"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/balanceAmount"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="12dp"/>

            <!-- Main Budget Amount -->
            <TextView
                android:id="@+id/mainBudgetAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00.00 ZAR"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/teal_700"
                app:layout_constraintBaseline_toBaselineOf="@id/mainBudgetLabel"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Total Spending Label -->
            <TextView
                android:id="@+id/spendingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Spending"
                android:textSize="16sp"
                android:textColor="@color/black"
                app:layout_constraintTop_toBottomOf="@id/mainBudgetLabel"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp"/>

            <!-- Total Spending Amount -->
            <TextView
                android:id="@+id/spendingAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00.00 ZAR"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#E60E0E"
                app:layout_constraintBaseline_toBaselineOf="@id/spendingLabel"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Decorative Image -->
            <ImageView
                android:id="@+id/budgetImage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="72dp"
                android:layout_marginBottom="80dp"
                android:src="@drawable/visual"
                android:onClick="SHowtotal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>


    <!-- Main Content -->
    <FrameLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_card"
        app:layout_constraintTop_toBottomOf="@id/balanceCard"
        app:layout_constraintBottom_toTopOf="@id/bottomOptions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="16dp">

        <!-- 3 Option Cards LinearLayout -->
        <LinearLayout
            android:id="@+id/optionsRow"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="5dp"
            android:layout_gravity="top">

            <!-- Visual Card -->
            <androidx.cardview.widget.CardView
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:background="@android:color/white"
                android:layout_margin="8dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:onClick="vs_view"
                    android:background="@android:color/white"

                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/visual"
                        android:contentDescription="Visual" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visual"
                        android:textSize="14sp"
                        android:textColor="@android:color/black"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Track and Well Spending Card -->
            <androidx.cardview.widget.CardView
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                android:onClick="spendings"

                app:cardElevation="4dp"
                android:background="@android:color/white"
                android:layout_margin="8dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:onClick="spendings"
                    android:background="@android:color/white"

                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/track"
                        android:onClick="spendings"

                        android:contentDescription="Track" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spending"
                        android:textSize="14sp"
                        android:textColor="@android:color/black"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Game Card -->
            <androidx.cardview.widget.CardView
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:background="@android:color/white"
                android:layout_margin="8dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:gravity="center"
                    android:onClick="Gmaings"

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/white"

                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/game"

                        android:contentDescription="Game" />

                    <TextView
                        android:id="@+id/gamins"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textAlignment="center"
                        android:textColor="@android:color/black"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="2dp"
                        />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@android:color/black"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="2dp"
                        />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Sliding cards row - ViewPager2 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/sliderView"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_gravity="bottom"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:clipToPadding="false"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:background="@drawable/bg_gradient_card"
            android:overScrollMode="never"/>



    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomOptions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="3"
        android:background="#00FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="0dp">

        <!-- CardView: Home -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardElevation="1dp"
            app:cardCornerRadius="12dp"
            android:layout_margin="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp"
                android:onClick="logout"
                android:background="@android:color/white"

                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/home"
                    android:contentDescription="Home Icon"
                    app:tint="#787777"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logout"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CardView: View -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardElevation="1dp"
            app:cardCornerRadius="12dp"
            android:layout_margin="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:onClick="viewing"

                android:padding="12dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/view"
                    app:tint="#787777"
                    android:contentDescription="View Icon"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View"

                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CardView: Create -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardElevation="1dp"
            app:cardCornerRadius="12dp"
            android:layout_margin="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp"
                android:onClick="create_category"
                android:background="@android:color/white"

                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/create"
                    app:tint="#787777"
                    android:contentDescription="Create Icon"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>


    <!--  Floating Add Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_add"
        android:background="@drawable/bg_gradient_card"
        app:layout_constraintBottom_toTopOf="@id/bottomOptions"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="20dp"
        android:onClick="adds"
        app:backgroundTint="#D5D5D5"/>

</androidx.constraintlayout.widget.ConstraintLayout>
