<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".spendings"
    android:background="@android:color/white">

    <!-- Top Bar with Back Icon -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/arrow_back"
            android:contentDescription="Back"
            android:onClick="back_home" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Your Budget"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#000000" />
    </LinearLayout>

    <!-- Horizontal Cards Section -->
    <HorizontalScrollView
        android:id="@+id/horizontalCardScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/cardContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Main Budget Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMainBudget"
                android:layout_width="200dp"
                android:layout_height="120dp"
                android:layout_marginEnd="12dp"
                android:layout_marginVertical="8dp"
                android:background="@android:color/white"
                app:cardCornerRadius="16dp"
                android:layout_margin="5dp"

                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="@android:color/white"

                    android:gravity="center">

                    <TextView
                        android:id="@+id/mainBudgetText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Main Budget"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Main Budget"
                        android:textSize="18sp"
                        android:textColor="#444444"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Available Balance Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAvailableBalance"
                android:layout_width="200dp"
                android:layout_margin="5dp"

                android:layout_height="120dp"
                android:layout_marginEnd="12dp"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="@android:color/white"

                    android:gravity="center">

                    <TextView
                        android:id="@+id/availableBalanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 ZAR"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available"
                        android:textSize="18sp"
                        android:textColor="#444444"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total Spending Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpending"
                android:layout_width="200dp"
                android:layout_height="120dp"
                android:layout_marginVertical="8dp"
                android:background="@android:color/white"
                app:cardCornerRadius="16dp"
                android:layout_margin="5dp"

                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/white"

                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/spendingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spent"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spent"
                        android:textSize="18sp"
                        android:textColor="#444444"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </HorizontalScrollView>






    <!-- Action Options: Top Up and Clear All -->
    <LinearLayout
        android:id="@+id/actionOptionsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/horizontalCardScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Top Up Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardTopUp"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginEnd="8dp"
            android:layout_margin="5dp"
            android:layout_weight="1"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_card"
android:onClick="tops"

                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top Up"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Clear All Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardClearAll"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            app:cardCornerRadius="12dp"
            android:layout_margin="5dp"

            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_card"
android:onClick="clears"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear All"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>


    <FrameLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/bg_gradient_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/actionOptionsLayout"

        >
        <!-- PieChart -->
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/categoryPieChart"
            android:layout_width="350dp"
            android:layout_height="250dp"
            android:layout_marginTop="1dp"
            android:layout_marginLeft="30dp"
            android:visibility="visible" />

        <!-- Sliding cards row - ViewPager2 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/sliderViews"
            android:layout_width="match_parent"
            android:layout_height="194dp"
            android:layout_gravity="bottom"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_gradient_card"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="0dp"
            android:paddingEnd="0dp" />
    </FrameLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
